{
  "name": "pixel-vscode",
  "displayName": "Pixel VSCode",
  "description": "Create and edit pixel art PNG files directly in VS Code.",
  "version": "0.1.0",
  "publisher": "majinbaka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/majinbaka/pixel-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:pixelVscode.pixelEditor",
    "onCustomEditor:pixelVscode.mapEditor",
    "onCommand:pixelVscode.newFile",
    "onCommand:pixelVscode.newGodotMap",
    "onCommand:pixelVscode.newPixelMonsterCharacter",
    "onCommand:pixelVscode.openEditor",
    "onCommand:pixelVscode.previewAnimation",
    "onCommand:pixelVscode.syncPixelMonsterCharacter"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixelVscode.newFile",
        "title": "Pixel: New Pixel Image"
      },
      {
        "command": "pixelVscode.openEditor",
        "title": "Pixel: Open With Pixel Editor"
      },
      {
        "command": "pixelVscode.previewAnimation",
        "title": "Pixel: Preview PNG Animation"
      },
      {
        "command": "pixelVscode.newGodotMap",
        "title": "Pixel: New Pixel Monster Map"
      },
      {
        "command": "pixelVscode.newPixelMonsterCharacter",
        "title": "Pixel: New Pixel Monster Character"
      },
      {
        "command": "pixelVscode.syncPixelMonsterCharacter",
        "title": "Pixel: Validate and Sync Character Pack"
      }
    ],
    "configuration": {
      "title": "Pixel VSCode",
      "properties": {
        "pixelVscode.godotExecutable": {
          "type": "string",
          "default": "godot",
          "description": "Godot executable used to export native map scenes."
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "pixelVscode.openEditor",
          "when": "resourceExtname == .png",
          "group": "navigation"
        },
        {
          "command": "pixelVscode.previewAnimation",
          "when": "resourceExtname == .png",
          "group": "navigation@2"
        },
        {
          "command": "pixelVscode.syncPixelMonsterCharacter",
          "when": "resourceExtname == .png",
          "group": "navigation@3"
        }
      ],
      "editor/title/context": [
        {
          "command": "pixelVscode.openEditor",
          "when": "resourceExtname == .png",
          "group": "navigation"
        },
        {
          "command": "pixelVscode.previewAnimation",
          "when": "resourceExtname == .png",
          "group": "navigation@2"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "pixelVscode.pixelEditor",
        "displayName": "Pixel Editor",
        "selector": [
          {
            "filenamePattern": "*.png"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "pixelVscode.mapEditor",
        "displayName": "Pixel Monster Map Editor",
        "selector": [
          {
            "filenamePattern": "*.pixelmap.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.2"
  }
}
